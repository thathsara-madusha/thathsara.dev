---
import { portfolioData } from "../data/portfolio.js";
---

<section id="experience" class="section container">
    <h2 class="section-title">Where I've Worked</h2>

    <div
        class="grid gap-8 grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(300px,1fr))] mb-20"
    >
        {
            portfolioData.experience.map((job) => (
                <div class="relative overflow-hidden bg-white/2 border border-white/10 p-8 rounded-lg transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-1 hover:bg-white/5 hover:shadow-[0_10px_30px_-15px_rgba(0,0,0,0.5)] group">
                    <div class="absolute top-0 left-0 w-[2px] h-full bg-indigo-500 scale-y-0 origin-bottom transition-transform duration-300 ease-in-out group-hover:scale-y-100 group-hover:origin-top" />
                    <div class="flex flex-wrap items-baseline gap-2 mb-2">
                        <h3 class="text-xl text-gray-100 m-0">{job.role}</h3>
                        <span class="text-indigo-500 font-semibold">
                            @ {job.company}
                        </span>
                    </div>
                    <p class="font-mono text-sm text-gray-400 m-0 mb-4">
                        {job.period}
                    </p>
                    <p class="text-gray-400 leading-relaxed m-0">
                        {job.description}
                    </p>
                </div>
            ))
        }
    </div>

    <div>
        <h3 class="text-2xl mb-8 text-white">Core Technologies</h3>
        <ul class="flex flex-wrap gap-4 p-0 m-0 list-none">
            {
                portfolioData.skills.map((skill) => (
                    <li class="bg-indigo-500/10 text-indigo-300 px-4 py-2 rounded-full text-sm font-medium border border-indigo-500/20 transition-all duration-200 hover:bg-indigo-500 hover:text-white hover:scale-105">
                        {skill}
                    </li>
                ))
            }
        </ul>
    </div>
</section>
