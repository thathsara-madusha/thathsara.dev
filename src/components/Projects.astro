---
import { portfolioData } from "../data/portfolio.js";
---

<section id="projects" class="section container">
    <h2 class="section-title">Some Things I've Built</h2>

    <div class="flex flex-col gap-16">
        {
            portfolioData.projects.map((project) => (
                <div class="relative grid grid-cols-12 items-center">
                    <div class="col-span-12 text-left bg-gray-900/40 p-10 lg:p-14 rounded-xl border border-white/5 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:bg-gray-900/60 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)]">
                        <p class="my-2.5 text-indigo-500 font-mono text-sm font-normal">
                            Featured Project
                        </p>
                        <h3 class="text-slate-200 text-[clamp(24px,5vw,28px)] font-bold m-0 mb-5">
                            <a
                                href={project.link}
                                class="text-inherit no-underline hover:text-indigo-500"
                            >
                                {project.title}
                            </a>
                        </h3>
                        <div class="shadow-[0_10px_30px_-15px_rgba(2,12,27,0.7)] text-gray-400 text-base leading-relaxed mb-5">
                            <p>{project.description}</p>
                        </div>
                        <ul class="flex flex-wrap relative z-10 m-0 mt-6 mb-2.5 p-0 list-none gap-[15px]">
                            {project.tech.map((tech) => (
                                <li class="font-mono text-[0.85rem] text-gray-400 whitespace-nowrap">
                                    {tech}
                                </li>
                            ))}
                        </ul>
                        <div class="flex items-center relative mt-2.5 text-slate-200 gap-[15px]">
                            <a
                                href={project.githubLink}
                                target="_blank"
                                aria-label="GitHub Link"
                                class="flex justify-center items-center hover:text-indigo-500"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    role="img"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="feather feather-github"
                                >
                                    <>
                                        <title>GitHub</title>
                                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                                    </>
                                </svg>
                            </a>
                            <a
                                href={project.liveLink}
                                target="_blank"
                                aria-label="External Link"
                                class="flex justify-center items-center hover:text-indigo-500"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    role="img"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="feather feather-external-link w-5 h-5"
                                >
                                    <>
                                        <title>External Link</title>
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                        <polyline points="15 3 21 3 21 9" />
                                        <line x1="10" y1="14" x2="21" y2="3" />
                                    </>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>
